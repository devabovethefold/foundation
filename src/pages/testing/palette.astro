---
import Layout from '@layouts/Common.astro'

import { getSemanticBases, generateScale } from '@utilities/themes/colors'

const BRAND_BASE = '#195230'

const semanticBases = getSemanticBases(BRAND_BASE)

const brandScale = {
  name: 'Primary',
  title: 'Primary',
  key: 'base',
  colors: generateScale(semanticBases.base),
}

const semanticScales = [
  {
    name: 'Success',
    title: 'Success',
    key: 'success',
    colors: generateScale(semanticBases.success),
  },
  { name: 'Info', title: 'Info', key: 'info', colors: generateScale(semanticBases.info) },
  {
    name: 'Warning',
    title: 'Warning',
    key: 'warning',
    colors: generateScale(semanticBases.warning),
  },
  { name: 'Danger', title: 'Danger', key: 'error', colors: generateScale(semanticBases.error) },
]

const supportScales = [
  { name: 'Accent', title: 'Accent', key: 'accent', colors: generateScale(semanticBases.accent) },
  {
    name: 'Neutral',
    title: 'Neutral',
    key: 'neutral',
    colors: generateScale(semanticBases.neutral),
  },
]

const allScales = [brandScale, ...semanticScales, ...supportScales]
const coreSteps = ['100', '200', '300', '400', '500', '600', '700', '800', '900']
const lightSurfaceSteps = ['01', '05', '10', '50']
const darkSurfaceSteps = ['950', '990', '995', '999']
---

<Layout>
  <div class="min-h-screen bg-slate-50/50 p-6 md:p-12">
    
    <!-- Top Level Wrapper: Allows columns to flow in a row on desktop and wrap on small screens -->
    <div class="mx-auto flex max-w-[120rem] flex-wrap justify-between gap-12 xl:flex-nowrap xl:gap-16">
      
      <!-- 1. Brand Color Group -->
      <div class="flex flex-col gap-6 xl:w-64 xl:shrink-0">
        <!-- Header -->
        <div class="flex items-center gap-3 border-b-2 border-slate-200 pb-4">
          <div class="flex h-8 w-8 items-center justify-center rounded-full border border-slate-300 bg-white text-sm font-bold text-slate-800">1</div>
          <h2 class="text-lg font-bold tracking-tight text-slate-800">Brand Color</h2>
        </div>
        <!-- Column Grid -->
        <div class="grid grid-cols-1 gap-8">
          {[brandScale].map(scale => (
            <div class="flex flex-col gap-4">
              <!-- Top Card Preview -->
              <div class="flex items-center justify-between rounded-xl border border-slate-100 bg-white p-3 shadow-sm">
                <div class="flex flex-col">
                  <span class="text-[0.65rem] font-bold tracking-wider text-slate-400 uppercase">{scale.title}</span>
                  <div class="flex items-center gap-2 mt-1">
                    <div class="h-6 w-6 rounded shadow-inner" style={`background-color: var(--${scale.key}-500);`}></div>
                    <code class="font-mono text-sm font-bold text-slate-800">{scale.colors['500']}</code>
                  </div>
                </div>
              </div>

              <!-- Core Scale 100-900 -->
               <div class="flex flex-col overflow-hidden rounded-xl border border-slate-100 bg-white shadow-sm">
                 {coreSteps.map(step => {
                   const isDark = parseInt(step) >= 500;
                   return (
                     <div class={`group flex h-[3.25rem] w-full cursor-crosshair items-center justify-between px-4 transition-transform hover:z-10 hover:scale-[1.02] hover:shadow-md ${isDark ? 'text-white' : 'text-slate-800'}`} style={`background-color: var(--${scale.key}-${step});`}>
                       <span class="w-8 text-xs font-bold opacity-60">{step}</span>
                       <span class="font-mono text-xs font-semibold tracking-wider opacity-0 transition-opacity group-hover:opacity-100">{scale.colors[step]}</span>
                     </div>
                   );
                 })}
               </div>

               <!-- Surface Extrapolations -->
               <div class="mt-2 flex gap-2">
                 <!-- Light Surfaces -->
                 <div class="flex flex-1 flex-col overflow-hidden rounded-lg border border-slate-100 shadow-sm opacity-90">
                   {lightSurfaceSteps.map(step => (
                     <div class="group flex h-8 w-full cursor-crosshair items-center justify-between px-2 transition-transform hover:z-10 hover:scale-105 hover:shadow-md text-slate-800" style={`background-color: var(--${scale.key}-${step});`}>
                       <span class="text-[0.6rem] font-bold opacity-60">{step}</span>
                     </div>
                   ))}
                 </div>
                 <!-- Dark Surfaces -->
                 <div class="flex flex-1 flex-col overflow-hidden rounded-lg border border-slate-100 shadow-sm opacity-90">
                     {darkSurfaceSteps.map(step => (
                     <div class="group flex h-8 w-full cursor-crosshair items-center justify-between px-2 transition-transform hover:z-10 hover:scale-105 hover:shadow-md text-white" style={`background-color: var(--${scale.key}-${step});`}>
                       <span class="text-[0.6rem] font-bold opacity-60">{step}</span>
                     </div>
                   ))}
                 </div>
               </div>
            </div>
          ))}
        </div>
      </div>

      <!-- 2. Semantic Colors Group -->
      <div class="flex flex-1 flex-col gap-6">
        <!-- Header -->
        <div class="flex items-center gap-3 border-b-2 border-slate-200 pb-4">
          <div class="flex h-8 w-8 items-center justify-center rounded-full border border-slate-300 bg-white text-sm font-bold text-slate-800">2</div>
          <h2 class="text-lg font-bold tracking-tight text-slate-800">Semantic Colors</h2>
        </div>
        <!-- Column Grid: Wraps correctly inline -->
        <div class="grid grid-cols-1 sm:grid-cols-2 max-xl:gap-8 lg:grid-cols-4 xl:gap-6">
          {semanticScales.map(scale => (
            <div class="flex flex-col gap-4">
              <!-- Top Card Preview -->
              <div class="flex items-center justify-between rounded-xl border border-slate-100 bg-white p-3 shadow-sm">
                <div class="flex flex-col">
                  <span class="text-[0.65rem] font-bold tracking-wider text-slate-400 uppercase">{scale.title}</span>
                  <div class="flex items-center gap-2 mt-1">
                    <div class="h-6 w-6 rounded shadow-inner" style={`background-color: var(--${scale.key}-500);`}></div>
                    <code class="font-mono text-sm font-bold text-slate-800">{scale.colors['500']}</code>
                  </div>
                </div>
              </div>

               <!-- Core Scale 100-900 -->
               <div class="flex flex-col overflow-hidden rounded-xl border border-slate-100 bg-white shadow-sm">
                 {coreSteps.map(step => {
                   const isDark = parseInt(step) >= 500;
                   return (
                     <div class={`group flex h-[3.25rem] w-full cursor-crosshair items-center justify-between px-4 transition-transform hover:z-10 hover:scale-[1.02] hover:shadow-md ${isDark ? 'text-white' : 'text-slate-800'}`} style={`background-color: var(--${scale.key}-${step});`}>
                       <span class="w-8 text-xs font-bold opacity-60">{step}</span>
                       <span class="font-mono text-xs font-semibold tracking-wider opacity-0 transition-opacity group-hover:opacity-100">{scale.colors[step]}</span>
                     </div>
                   );
                 })}
               </div>

               <!-- Surface Extrapolations -->
               <div class="mt-2 flex gap-2">
                 <div class="flex flex-1 flex-col overflow-hidden rounded-lg border border-slate-100 shadow-sm opacity-90">
                   {lightSurfaceSteps.map(step => (
                     <div class="group flex h-8 w-full cursor-crosshair items-center justify-between px-2 transition-transform hover:z-10 hover:scale-105 hover:shadow-md text-slate-800" style={`background-color: var(--${scale.key}-${step});`}>
                       <span class="text-[0.6rem] font-bold opacity-60">{step}</span>
                     </div>
                   ))}
                 </div>
                 <div class="flex flex-1 flex-col overflow-hidden rounded-lg border border-slate-100 shadow-sm opacity-90">
                     {darkSurfaceSteps.map(step => (
                     <div class="group flex h-8 w-full cursor-crosshair items-center justify-between px-2 transition-transform hover:z-10 hover:scale-105 hover:shadow-md text-white" style={`background-color: var(--${scale.key}-${step});`}>
                       <span class="text-[0.6rem] font-bold opacity-60">{step}</span>
                     </div>
                   ))}
                 </div>
               </div>
            </div>
          ))}
        </div>
      </div>

      <!-- 3. Support Colors Group -->
      <div class="flex flex-col gap-6 xl:w-[28rem] xl:shrink-0">
        <!-- Header -->
        <div class="flex items-center gap-3 border-b-2 border-slate-200 pb-4">
          <div class="flex h-8 w-8 items-center justify-center rounded-full border border-slate-300 bg-white text-sm font-bold text-slate-800">3</div>
          <h2 class="text-lg font-bold tracking-tight text-slate-800">Support Colors</h2>
        </div>
        <!-- Column Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 max-xl:gap-8 xl:gap-6">
          {supportScales.map(scale => (
            <div class="flex flex-col gap-4">
              <!-- Top Card Preview -->
              <div class="flex items-center justify-between rounded-xl border border-slate-100 bg-white p-3 shadow-sm">
                <div class="flex flex-col">
                  <span class="text-[0.65rem] font-bold tracking-wider text-slate-400 uppercase">{scale.title}</span>
                  <div class="flex items-center gap-2 mt-1">
                    <div class="h-6 w-6 rounded shadow-inner" style={`background-color: var(--${scale.key}-500);`}></div>
                    <code class="font-mono text-sm font-bold text-slate-800">{scale.colors['500']}</code>
                  </div>
                </div>
              </div>

               <!-- Core Scale 100-900 -->
               <div class="flex flex-col overflow-hidden rounded-xl border border-slate-100 bg-white shadow-sm">
                 {coreSteps.map(step => {
                   const isDark = parseInt(step) >= 500;
                   return (
                     <div class={`group flex h-[3.25rem] w-full cursor-crosshair items-center justify-between px-4 transition-transform hover:z-10 hover:scale-[1.02] hover:shadow-md ${isDark ? 'text-white' : 'text-slate-800'}`} style={`background-color: var(--${scale.key}-${step});`}>
                       <span class="w-8 text-xs font-bold opacity-60">{step}</span>
                       <span class="font-mono text-xs font-semibold tracking-wider opacity-0 transition-opacity group-hover:opacity-100">{scale.colors[step]}</span>
                     </div>
                   );
                 })}
               </div>

               <!-- Surface Extrapolations -->
               <div class="mt-2 flex gap-2">
                 <div class="flex flex-1 flex-col overflow-hidden rounded-lg border border-slate-100 shadow-sm opacity-90">
                   {lightSurfaceSteps.map(step => (
                     <div class="group flex h-8 w-full cursor-crosshair items-center justify-between px-2 transition-transform hover:z-10 hover:scale-105 hover:shadow-md text-slate-800" style={`background-color: var(--${scale.key}-${step});`}>
                       <span class="text-[0.6rem] font-bold opacity-60">{step}</span>
                     </div>
                   ))}
                 </div>
                 <div class="flex flex-1 flex-col overflow-hidden rounded-lg border border-slate-100 shadow-sm opacity-90">
                     {darkSurfaceSteps.map(step => (
                     <div class="group flex h-8 w-full cursor-crosshair items-center justify-between px-2 transition-transform hover:z-10 hover:scale-105 hover:shadow-md text-white" style={`background-color: var(--${scale.key}-${step});`}>
                       <span class="text-[0.6rem] font-bold opacity-60">{step}</span>
                     </div>
                   ))}
                 </div>
               </div>
            </div>
          ))}
        </div>
      </div>
      
    </div>
  </div>
</Layout>
