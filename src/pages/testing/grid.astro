---
import Layout from '@layouts/Common.astro'
---

<Layout>
  <section class="mb-12">
    <div class="col-start-grid col-span-12 mb-4 text-center">
      <h2 class="text-3xl font-bold">12-Column Grid Test</h2>
      <p class="text-zinc-500">Testing our new mathematical layout system.</p>
    </div>

    <!-- 1/2 Split -->
    <div class="col-start-grid half flex h-24 items-center justify-center bg-blue-100 font-medium text-blue-700 dark:bg-blue-900/30 dark:text-blue-300">
      1/2 (6 Columns)
    </div>
    <div class="half flex h-24 items-center justify-center bg-blue-200 font-medium text-blue-800 dark:bg-blue-800/40 dark:text-blue-200">
      1/2 (6 Columns)
    </div>

    <!-- 1/3 Split -->
    <div class="col-start-grid third flex h-24 items-center justify-center bg-emerald-100 font-medium text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300">
      1/3 (4 Columns)
    </div>
    <div class="third flex h-24 items-center justify-center bg-emerald-200 font-medium text-emerald-800 dark:bg-emerald-800/40 dark:text-emerald-200">
      1/3 (4 Columns)
    </div>
    <div class="third flex h-24 items-center justify-center bg-emerald-300 font-medium text-emerald-900 dark:bg-emerald-700/50 dark:text-emerald-100">
      1/3 (4 Columns)
    </div>

    <!-- Mixed Ratios: 1/4 + 1/2 + 1/4 -->
    <div class="col-start-grid fourth flex h-24 items-center justify-center bg-amber-100 font-medium text-amber-700 dark:bg-amber-900/30 dark:text-amber-300">
      1/4 (3 Cols)
    </div>
    <div class="half flex h-24 items-center justify-center bg-amber-200 font-medium text-amber-800 dark:bg-amber-800/40 dark:text-amber-200">
      1/2 (6 Cols)
    </div>
    <div class="fourth flex h-24 items-center justify-center bg-amber-100 font-medium text-amber-700 dark:bg-amber-900/30 dark:text-amber-300">
      1/4 (3 Cols)
    </div>

    <!-- Complex Mixed: 1/12 + 5/12 + 1/2 -->
    <div class="col-start-grid twelfth flex h-24 items-center justify-center bg-purple-100 text-xs font-medium text-purple-700 dark:bg-purple-900/30 dark:text-purple-300">
      1/12
    </div>
    <div class="col-span-5 flex h-24 items-center justify-center bg-purple-200 font-medium text-purple-800 dark:bg-purple-800/40 dark:text-purple-200">
      5/12 (Using standard col-span)
    </div>
    <div class="half flex h-24 items-center justify-center bg-purple-300 font-medium text-purple-900 dark:bg-purple-700/50 dark:text-purple-100">
      1/2 (6 Cols)
    </div>
  </section>

  <!-- Breakout Context Demo -->
  <section class="breakout py-content bg-zinc-50 dark:bg-zinc-900/20">
    <div class="col-start-grid col-span-14 mb-4 text-center">
      <h3 class="text-xl font-bold italic">Contextual Breakout Grid (14 Columns)</h3>
      <p class="text-zinc-500">Notice how the "Half" columns below are wider than the standard ones above.</p>
    </div>
    <div class="col-start-grid half flex h-32 items-center justify-center bg-rose-100 font-bold text-rose-700 dark:bg-rose-900/30 dark:text-rose-300">
      Breakout Half (7 Cols)
    </div>
    <div class="half flex h-32 items-center justify-center bg-rose-200 font-bold text-rose-800 dark:bg-rose-800/40 dark:text-rose-200">
      Breakout Half (7 Cols)
    </div>
  </section>

  <!-- Width Demonstration -->
  <section class="max-w-none">
    <div class="fullwidth mb-4 flex h-16 items-center justify-center bg-zinc-800 text-white dark:bg-zinc-100 dark:text-zinc-900">
      Fullwidth (Spans fullwidth-start to fullwidth-end)
    </div>
    <div class="breakout mb-4 flex h-16 items-center justify-center bg-zinc-200 dark:bg-zinc-800">
      Breakout (Spans breakout-start to breakout-end)
    </div>
    <div class="flex h-16 items-center justify-center bg-zinc-100 dark:bg-zinc-900">
      Standard Content (Automatic Centered 12 Columns)
    </div>
  </section>
</Layout>
